<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To show the listing details</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="listing-container">
        <div class="listing-card">
            <img src="<%= listing.image.url %>" alt="listing image" class="listing-image">
            <div class="listing-content">
                <h1 class="listing-title"><%= listing.title %></h1>
                <p class="listing-description"><%= listing.description %></p>
                <div class="listing-details">
                    <p class="listing-price"><span class="label">Price:</span> $<%= listing.price %></p>
                    <p class="listing-location"><span class="label">Location:</span> <%= listing.location %></p>
                    <p class="listing-country"><span class="label">Country:</span> <%= listing.country %></p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>