<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hotel Listings</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="listing-page">
    <div class="listing-header">
      <h1 class="page-title">🏨 All Hotel Listings</h1>
      <p class="page-subtitle">Discover amazing places to stay</p>
    </div>

    <ul class="listings-grid">
      <% listings.forEach(listing => { %>
        <li class="listing-card">
          <a href="/listings/<%= listing._id %>" class="card-link">
            <div class="card-wrapper">
              <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="card-image">
              <div class="card-body">
                <h3 class="card-title"><%= listing.title %></h3>
                <p class="card-location">📍 <%= listing.location %></p>
                <div class="card-footer">
                  <span class="card-price">$<%= listing.price %>/night</span>
                </div>
              </div>
            </div>
          </a>
        </li>
      <% }) %>
    </ul>
  </div>
</body>
</html>